# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/priority_crm"
DATABASE_DIRECT_URL="postgresql://postgres:postgres@localhost:5432/priority_crm"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""

# ─── API ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
API_PREFIX=api/v1
CORS_ORIGINS="http://localhost:3000"

# ─── Auth / JWT ──────────────────────────────────────────────────────────────
JWT_SECRET="change-me-in-production-use-openssl-rand-base64-64"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"
NEXT_PUBLIC_WS_URL="ws://localhost:3001"
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ─── Claude AI ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-sonnet-4-6"

# ─── WhatsApp (Twilio / Meta Cloud API) ──────────────────────────────────────
WHATSAPP_PROVIDER="meta"
META_WHATSAPP_TOKEN=""
META_WHATSAPP_PHONE_ID=""
META_WHATSAPP_WEBHOOK_SECRET=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_NUMBER=""

# ─── Email (SMTP / SendGrid / Resend) ────────────────────────────────────────
EMAIL_PROVIDER="smtp"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@priority-crm.com"
SENDGRID_API_KEY=""
RESEND_API_KEY=""

# ─── VoIP (Twilio Voice) ─────────────────────────────────────────────────────
TWILIO_VOICE_APP_SID=""
TWILIO_VOICE_CALLER_ID=""

# ─── File Storage ────────────────────────────────────────────────────────────
STORAGE_PROVIDER="local"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET=""
