// Priority CRM - Prisma Schema
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_DIRECT_URL")
}

// ─── Organization ────────────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String?  @unique
  logo      String?
  settings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  contacts    Contact[]
  deals       Deal[]
  stages      PipelineStage[]
  conversations Conversation[]
  automations Automation[]
  tags        Tag[]
  calendarEvents CalendarEvent[]
  trainingVideos TrainingVideo[]
  clientes    Cliente[]
  polizas     Poliza[]

  @@map("organizations")
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  password       String
  avatar         String?
  role           UserRole @default(SALES_REP)
  phone          String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contacts       Contact[]     @relation("ContactCreatedBy")
  assignedContacts Contact[]   @relation("ContactAssignedTo")
  deals          Deal[]        @relation("DealCreatedBy")
  assignedDeals  Deal[]        @relation("DealAssignedTo")
  activities     Activity[]
  automations    Automation[]
  sentMessages      Message[]
  pushSubscriptions PushSubscription[]
  createdCalendarEvents    CalendarEvent[]            @relation("CalendarEventCreatedBy")
  calendarParticipations   CalendarEventParticipant[]
  createdTrainingVideos   TrainingVideo[]      @relation("TrainingVideoCreatedBy")
  trainingVideoViews      TrainingVideoView[]
  sentWhatsappMessages    WhatsappMessage[]
  clientesAsignados       Cliente[]           @relation("ClienteEjecutivo")
  clientesCreados         Cliente[]           @relation("ClienteCreatedBy")
  polizasComoAgente       Poliza[]            @relation("PolizaAgente")

  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  OWNER
  MANAGER
  SALES_REP
  // Perfiles del módulo de Operaciones
  OPERACIONES      // ejecutivo de cuenta: ve SOLO sus clientes
  JEFE_OPERACIONES // ve todos los clientes
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@map("push_subscriptions")
}

// ─── Contacts ────────────────────────────────────────────────────────────────

model Contact {
  id             String        @id @default(cuid())
  firstName      String
  lastName       String?
  email          String?
  phone          String?
  company        String?
  position       String?
  avatar         String?
  status         ContactStatus @default(ACTIVE)
  source         String?
  notes          String?
  customFields   Json?
  organizationId String
  createdById    String
  assignedToId   String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User           @relation("ContactCreatedBy", fields: [createdById], references: [id])
  assignedTo   User?          @relation("ContactAssignedTo", fields: [assignedToId], references: [id])
  deals        Deal[]
  activities   Activity[]
  conversations Conversation[]
  tags         Tag[]          @relation("ContactTags")
  cliente      Cliente?

  @@index([organizationId])
  @@index([email])
  @@index([phone])
  @@map("contacts")
}

enum ContactStatus {
  ACTIVE
  INACTIVE
  LEAD
  CUSTOMER
  CHURNED
}

// ─── Pipeline ────────────────────────────────────────────────────────────────

model PipelineStage {
  id             String   @id @default(cuid())
  name           String
  color          String   @default("#6366f1")
  position       Int
  probability    Int      @default(0)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deals        Deal[]

  @@index([organizationId, position])
  @@map("pipeline_stages")
}

model Deal {
  id               String     @id @default(cuid())
  title            String
  value            Float?
  currency         String     @default("USD")
  probability      Int?
  expectedCloseDate DateTime?
  closedAt         DateTime?
  status           DealStatus @default(OPEN)
  notes            String?
  customFields     Json?
  position         Int        @default(0)
  stageId          String
  contactId        String?
  organizationId   String
  createdById      String
  assignedToId     String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  stage        PipelineStage @relation(fields: [stageId], references: [id])
  contact      Contact?      @relation(fields: [contactId], references: [id])
  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User          @relation("DealCreatedBy", fields: [createdById], references: [id])
  assignedTo       User?            @relation("DealAssignedTo", fields: [assignedToId], references: [id])
  activities       Activity[]
  whatsappMessages WhatsappMessage[]

  @@index([organizationId])
  @@index([stageId, position])
  @@map("deals")
}

enum DealStatus {
  OPEN
  WON
  LOST
}

// ─── Communications ───────────────────────────────────────────────────────────

model Conversation {
  id             String              @id @default(cuid())
  channel        CommunicationChannel
  status         ConversationStatus  @default(OPEN)
  externalId     String?
  contactId      String?
  organizationId String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  contact      Contact?     @relation(fields: [contactId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages     Message[]

  @@index([organizationId, channel])
  @@index([contactId])
  @@map("conversations")
}

model Message {
  id             String          @id @default(cuid())
  conversationId String
  content        String
  type           MessageType     @default(TEXT)
  direction      MessageDirection
  read           Boolean         @default(false)
  externalId     String?
  metadata       Json?
  sentById       String?
  createdAt      DateTime        @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sentBy       User?        @relation(fields: [sentById], references: [id])

  @@index([conversationId])
  @@map("messages")
}

enum CommunicationChannel {
  WHATSAPP
  EMAIL
  VOIP
  SMS
}

enum ConversationStatus {
  OPEN
  CLOSED
  PENDING
}

enum MessageType {
  TEXT
  IMAGE
  DOCUMENT
  AUDIO
  VIDEO
  TEMPLATE
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

// ─── Activities ───────────────────────────────────────────────────────────────

model Activity {
  id             String       @id @default(cuid())
  type           ActivityType
  description    String
  metadata       Json?
  contactId      String?
  dealId         String?
  userId         String?
  organizationId String
  createdAt      DateTime     @default(now())

  contact Contact? @relation(fields: [contactId], references: [id])
  deal    Deal?    @relation(fields: [dealId], references: [id])
  user    User?    @relation(fields: [userId], references: [id])

  @@index([contactId])
  @@index([dealId])
  @@map("activities")
}

enum ActivityType {
  NOTE
  CALL
  EMAIL
  MEETING
  TASK
  STAGE_CHANGE
  DEAL_CREATED
  CONTACT_CREATED
  MESSAGE_SENT
  MESSAGE_RECEIVED
}

// ─── Automations ─────────────────────────────────────────────────────────────

model Automation {
  id             String   @id @default(cuid())
  name           String
  description    String?
  trigger        String
  conditions     Json?
  actions        Json
  isActive       Boolean  @default(true)
  organizationId String
  createdById    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation(fields: [createdById], references: [id])

  @@index([organizationId, trigger])
  @@map("automations")
}

// ─── Calendar ────────────────────────────────────────────────────────────────

model CalendarEvent {
  id             String                @id @default(cuid())
  title          String
  description    String?
  startAt        DateTime
  endAt          DateTime?
  givenBy        String?
  modality       CalendarEventModality @default(PRESENCIAL)
  meetingLink    String?
  organizationId String
  createdById    String
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  organization Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User                       @relation("CalendarEventCreatedBy", fields: [createdById], references: [id])
  participants CalendarEventParticipant[]

  @@index([organizationId, startAt])
  @@map("calendar_events")
}

model CalendarEventParticipant {
  id      String @id @default(cuid())
  eventId String
  userId  String

  event CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@map("calendar_event_participants")
}

enum CalendarEventModality {
  PRESENCIAL
  VIRTUAL
}

// ─── Tags ────────────────────────────────────────────────────────────────────

model Tag {
  id             String   @id @default(cuid())
  name           String
  color          String   @default("#6366f1")
  organizationId String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contacts     Contact[]    @relation("ContactTags")

  @@unique([name, organizationId])
  @@map("tags")
}

// ─── Training ────────────────────────────────────────────────────────────────

model TrainingVideo {
  id              String           @id @default(cuid())
  title           String
  description     String?
  youtubeUrl      String
  category        TrainingCategory
  durationMinutes Int?
  organizationId  String
  createdById     String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User                @relation("TrainingVideoCreatedBy", fields: [createdById], references: [id])
  views        TrainingVideoView[]

  @@index([organizationId, category])
  @@map("training_videos")
}

enum TrainingCategory {
  CRM_USAGE
  QUOTING_TOOLS
  VITALITY
  SALES_TECHNIQUES
  OTHER
}

model TrainingVideoView {
  id       String   @id @default(cuid())
  videoId  String
  userId   String
  viewedAt DateTime @default(now())

  video TrainingVideo @relation(fields: [videoId], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([videoId, userId])
  @@map("training_video_views")
}

// ─── WhatsApp Chat ────────────────────────────────────────────────────────────

model WhatsappMessage {
  id                String         @id @default(cuid())
  dealId            String
  direction         WaMsgDirection
  messageType       WaMsgType      @default(TEXT)
  content           String         @default("")
  mediaUrl          String?
  mediaFileName     String?
  sentByUserId      String?
  whatsappMessageId String?
  status            WaMsgStatus    @default(SENT)
  read              Boolean        @default(false)
  createdAt         DateTime       @default(now())

  deal   Deal  @relation(fields: [dealId], references: [id], onDelete: Cascade)
  sentBy User? @relation(fields: [sentByUserId], references: [id])

  @@index([dealId, createdAt])
  @@map("whatsapp_messages")
}

enum WaMsgDirection {
  INBOUND
  OUTBOUND
}

enum WaMsgType {
  TEXT
  DOCUMENT
  IMAGE
}

enum WaMsgStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

// ═══════════════════════════════════════════════════════════════════════
//  MÓDULO DE OPERACIONES — Base de clientes
//  Un Cliente es una persona (única por identificación). Tiene N pólizas y
//  N dependientes. Cada póliza registra a cuáles dependientes cubre.
// ═══════════════════════════════════════════════════════════════════════

enum Genero {
  MASCULINO
  FEMENINO
  OTRO
}

enum EstadoPoliza {
  NUEVO
  RENOVADO
  CARTA_DE_NOMBRAMIENTO
  CANCELADA
}

enum FormaPago {
  CONTADO
  MENSUAL
  DIFERIDO
  DIFERIDO_ESPECIAL
}

enum Parentesco {
  CONYUGE
  HIJO
  HIJA
  PADRE
  MADRE
  HERMANO
  HERMANA
  OTRO
}

model Cliente {
  id              String    @id @default(cuid())
  nombres         String
  apellidos       String
  identificacion  String
  genero          Genero?
  fechaNacimiento DateTime?

  email           String?
  telefono        String?
  celular         String?
  ciudad          String?
  direccion       String?
  notas           String?

  // Semáforo de calidad de datos: el registro entra igual, pero marcado.
  revisar         Boolean   @default(false)
  revisarMotivo   String?

  organizationId  String
  // Manda en los permisos: un usuario OPERACIONES solo lee clientes donde
  // ejecutivoId == su id. El filtro va en el servidor, nunca solo en la UI.
  ejecutivoId     String?
  ejecutivoNombre String?
  // Enganche con el área comercial: de qué contacto/lead salió este cliente.
  contactId       String?   @unique
  createdById     String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ejecutivo       User?         @relation("ClienteEjecutivo", fields: [ejecutivoId], references: [id])
  createdBy       User?         @relation("ClienteCreatedBy", fields: [createdById], references: [id])
  contact         Contact?      @relation(fields: [contactId], references: [id])
  polizas         Poliza[]
  dependientes    Dependiente[]

  @@unique([organizationId, identificacion])
  @@index([organizationId, ejecutivoId])
  @@index([organizationId, apellidos])
  @@index([identificacion])
  @@map("clientes")
}

model Poliza {
  id              String        @id @default(cuid())
  numeroContrato  String?
  estado          EstadoPoliza?
  aseguradora     String?
  plan            String?
  deducible       String?
  formaPago       FormaPago?
  fechaEmision    DateTime?
  fechaRenovacion DateTime?
  primaNeta       Decimal?      @db.Decimal(12, 2)

  revisar         Boolean       @default(false)
  revisarMotivo   String?

  clienteId       String
  organizationId  String
  agenteId        String?
  agenteNombre    String?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  cliente         Cliente             @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agente          User?               @relation("PolizaAgente", fields: [agenteId], references: [id])
  dependientes    PolizaDependiente[]

  @@index([clienteId])
  @@index([organizationId, aseguradora])
  @@index([organizationId, fechaRenovacion])
  @@map("polizas")
}

model Dependiente {
  id              String     @id @default(cuid())
  nombres         String
  apellidos       String?
  identificacion  String?
  fechaNacimiento DateTime?
  parentesco      Parentesco @default(OTRO)

  clienteId       String
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  cliente         Cliente             @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  polizas         PolizaDependiente[]

  @@index([clienteId])
  @@map("dependientes")
}

model PolizaDependiente {
  polizaId      String
  dependienteId String

  poliza        Poliza      @relation(fields: [polizaId], references: [id], onDelete: Cascade)
  dependiente   Dependiente @relation(fields: [dependienteId], references: [id], onDelete: Cascade)

  @@id([polizaId, dependienteId])
  @@index([dependienteId])
  @@map("poliza_dependientes")
}
